sudo snapper -c home list | awk 'NR>3 {print $1}' | xargs -r sudo snapper -c home delete --sync


# Restore drifted local packages when btrfs snapsho deletion failure
```
LC_ALL=C pacman -Qk 2>/dev/null | grep 'missing files' | grep -v ' 0 missing files' \
  | cut -d: -f1 | sort -u > /tmp/broken.txt

grep -Fxf <(pacman -Qnq) /tmp/broken.txt > /tmp/broken-native.txt
grep -Fxf <(pacman -Qmq) /tmp/broken.txt > /tmp/broken-foreign.txt

sudo pacman -S --overwrite '*' -- $(< /tmp/broken-native.txt)
yay -S $(< /tmp/broken-foreign.txt)
```
