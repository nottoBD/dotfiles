#!/bin/bash
# ~/.local/bin/switch-phinger-cursor  (chmod +x)

THEME_DARK="phinger-cursors-dark"
THEME_LIGHT="phinger-cursors-light"
THEME_DIR="$HOME/.icons/default"

if [ -z "$1" ] || [ "$1" = "toggle" ]; then
  CURRENT=$(grep -oP 'Inherits=\K.*' "$THEME_DIR/index.theme" 2>/dev/null || echo "$THEME_DARK")
  [[ "$CURRENT" == *dark* ]] && NEW="$THEME_LIGHT" || NEW="$THEME_DARK"
elif [ "$1" = "dark" ]; then NEW="$THEME_DARK"
elif [ "$1" = "light" ]; then NEW="$THEME_LIGHT"
else echo "Usage: $0 [toggle|dark|light]"; exit 1; fi

echo "🔄 Switching to $NEW..."

# Force default index.theme
mkdir -p "$THEME_DIR"
cat > "$THEME_DIR/index.theme" <<EOF
[Icon Theme]
Name=Default
Comment=Default Cursor Theme
Inherits=$NEW
EOF

# GTK3 + GTK4
for f in ~/.config/gtk-3.0/settings.ini ~/.config/gtk-4.0/settings.ini; do
  mkdir -p "$(dirname "$f")"
  sed -i "s/gtk-cursor-theme-name=.*/gtk-cursor-theme-name=$NEW/" "$f" 2>/dev/null || echo "gtk-cursor-theme-name=$NEW" >> "$f"
  sed -i "s/gtk-cursor-theme-size=.*/gtk-cursor-theme-size=24/" "$f" 2>/dev/null || echo "gtk-cursor-theme-size=24" >> "$f"
done

# Xresources
echo "Xcursor.theme: $NEW" > ~/.Xresources
xrdb -merge ~/.Xresources 2>/dev/null || true

# xsettingsd (GTK apps)
if pgrep -x xsettingsd >/dev/null; then
  sed -i "s/Gtk\/CursorThemeName.*/Gtk\/CursorThemeName \"$NEW\"/" ~/.config/xsettingsd/xsettingsd.conf 2>/dev/null || echo "Gtk/CursorThemeName \"$NEW\"" >> ~/.config/xsettingsd/xsettingsd.conf
  pkill -HUP xsettingsd
fi

# gsettings (extra insurance for some GTK apps)
gsettings set org.gnome.desktop.interface cursor-theme "$NEW" 2>/dev/null || true

# Hard root cursor reload
for i in {1..3}; do
  xsetroot -cursor_name left_ptr 2>/dev/null
  sleep 0.1
done

notify-send "Cursor switched" "$NEW" 2>/dev/null || echo "✅ Cursor switched to $NEW"
